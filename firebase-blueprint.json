{
  "entities": {
    "Task": {
      "title": "Task",
      "description": "A user task generated by the AI",
      "type": "object",
      "properties": {
        "user_id": { "type": "string" },
        "title": { "type": "string" },
        "raw_input": { "type": "string" },
        "deadline": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "in_progress", "completed", "failed"] },
        "priority_score": { "type": "number" },
        "shadow_artifacts": { "type": "object" },
        "collision_warning": { "type": "string" }
      },
      "required": ["user_id", "title", "raw_input", "deadline", "status", "priority_score", "shadow_artifacts"]
    },
    "CalendarEvent": {
      "title": "CalendarEvent",
      "description": "A calendar block event",
      "type": "object",
      "properties": {
        "user_id": { "type": "string" },
        "title": { "type": "string" },
        "start": { "type": "string" },
        "end": { "type": "string" },
        "isCalendarBlock": { "type": "boolean" }
      },
      "required": ["user_id", "title", "start", "end", "isCalendarBlock"]
    }
  },
  "firestore": {
    "/tasks/{taskId}": {
      "schema": { "$ref": "#/entities/Task" },
      "description": "User tasks"
    },
    "/calendarEvents/{eventId}": {
      "schema": { "$ref": "#/entities/CalendarEvent" },
      "description": "User calendar events"
    }
  }
}
