rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }

    function isSignedIn() {
      return request.auth != null && request.auth.token.email_verified == true;
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function isValidTask(data) {
      return data.keys().hasAll(['user_id', 'title', 'raw_input', 'deadline', 'status', 'priority_score', 'shadow_artifacts']) &&
             (data.keys().size() == 7 || (data.keys().hasAll(['collision_warning']) && data.keys().size() == 8)) &&
             data.user_id == request.auth.uid &&
             data.title is string && data.title.size() > 0 && data.title.size() <= 1000 &&
             data.raw_input is string && data.raw_input.size() <= 5000 &&
             data.deadline is string && data.deadline.size() <= 100 &&
             data.status in ['pending', 'in_progress', 'completed', 'failed'] &&
             data.priority_score is number &&
             data.shadow_artifacts is map &&
             (!('collision_warning' in data) || (data.collision_warning is string && data.collision_warning.size() <= 1000));
    }

    function isValidCalendarEvent(data) {
      return data.keys().hasAll(['user_id', 'title', 'start', 'end', 'isCalendarBlock']) &&
             data.keys().size() == 5 &&
             data.user_id == request.auth.uid &&
             data.title is string && data.title.size() > 0 && data.title.size() <= 500 &&
             data.start is string && data.start.size() <= 100 &&
             data.end is string && data.end.size() <= 100 &&
             data.isCalendarBlock is bool;
    }

    match /tasks/{taskId} {
      allow read: if isSignedIn() && existing().user_id == request.auth.uid;
      allow create: if isSignedIn() && isValidId(taskId) && isValidTask(incoming());
      allow update: if isSignedIn() && isValidId(taskId) && existing().user_id == request.auth.uid && isValidTask(incoming()) && incoming().user_id == existing().user_id;
      allow delete: if isSignedIn() && isValidId(taskId) && existing().user_id == request.auth.uid;
      allow list: if isSignedIn() && resource.data.user_id == request.auth.uid;
    }

    match /calendarEvents/{eventId} {
      allow read: if isSignedIn() && existing().user_id == request.auth.uid;
      allow create: if isSignedIn() && isValidId(eventId) && isValidCalendarEvent(incoming());
      allow update: if isSignedIn() && isValidId(eventId) && existing().user_id == request.auth.uid && isValidCalendarEvent(incoming()) && incoming().user_id == existing().user_id;
      allow delete: if isSignedIn() && isValidId(eventId) && existing().user_id == request.auth.uid;
      allow list: if isSignedIn() && resource.data.user_id == request.auth.uid;
    }
  }
}
